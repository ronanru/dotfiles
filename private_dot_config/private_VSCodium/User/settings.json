    "editor.tabSize": 4,
    "editor.defaultFormatter": "ms-python.python"
  },
  "terminal.integrated.fontFamily": "FiraCode Nerd Font",
  "cSpell.language": "en,ru",
  "telemetry.enableCrashReporter": false,
  "telemetry.enableTelemetry": false,
  "terminal.integrated.cursorStyle": "line",
  "editor.cursorBlinking": "solid",
  "git.enableSmartCommit": true,
  "editor.fontLigatures": true,
  "git.autofetch": true,
  "material-icon-theme.folders.theme": "specific",
  "material-icon-theme.activeIconPack": "",
  "material-icon-theme.hidesExplorerArrows": true,
  "cSpell.enabledLanguageIds": [
    "asciidoc",
    "c",
    "cpp",
    "csharp",
    "css",
    "git-commit",
    "go",
    "graphql",
    "handlebars",
    "haskell",
    "html",
    "jade",
    "java",
    "javascript",
    "javascriptreact",
    "json",
    "jsonc",
    "latex",
    "less",
    "markdown",
    "php",
    "plaintext",
    "python",
    "pug",
    "restructuredtext",
    "rust",
    "scala",
    "scss",
    "text",
    "typescript",
    "typescriptreact",
    "yaml",
    "yml",
    "svelte",
    "prisma"
  ],
  "cSpell.allowCompoundWords": true,
  "prettier.printWidth": 100,
  "prettier.singleQuote": true,
  "prettier.trailingComma": "none",
  "svelte.plugin.svelte.format.config.singleQuote": true,
  "svelte.plugin.svelte.format.config.printWidth": 175,
  "prettier.arrowParens": "avoid",
  "workbench.editor.untitled.hint": "hidden",
  "cSpell.userWords": [
    "behaviour",
    "CSRF",
    "fastify",
    "iframe",
    "noindex",
    "Ronan",
    "sveltejs",
    "tbody",
    "thead",
    "upvote",
    "upvoted",
    "vite",
    "webp",
    "Wretcher"
  ],
  "editor.renderWhitespace": "none",
  "workbench.tips.enabled": false,
  "diffEditor.wordWrap": "off",
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "svelte.enable-ts-plugin": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "window.menuBarVisibility": "hidden",
  "security.workspace.trust.enabled": false,
  "editor.formatOnSave": true,
  "[handlebars]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "gitlens.hovers.currentLine.over": "line",
  "gitlens.hovers.enabled": false,
  "gitlens.menus": false,
  "terminal.external.linuxExec": "kitty",
  "terminal.integrated.tabs.hideCondition": "singleGroup",
  "explorer.confirmDragAndDrop": false,
  "explorer.copyRelativePathSeparator": "/",
  "explorer.incrementalNaming": "smart",
  "workbench.editor.focusRecentEditorAfterClose": false,
  "workbench.editor.restoreViewState": false,
  "workbench.editor.showTabs": false,
  "window.restoreWindows": "none",
  "update.mode": "none",
  "gitlens.currentLine.enabled": false,
  "gitlens.codeLens.enabled": false,
  "files.hotExit": "off",
  "git.confirmSync": false,
  "files.associations": {
    ".env": "shellscript"
  },
  "editor.bracketPairColorization.enabled": true,
  "editor.cursorSmoothCaretAnimation": true,
  "editor.cursorWidth": 2,
  "cSpell.suggestionMenuType": "quickFix",
  "window.dialogStyle": "custom",
  "breadcrumbs.enabled": false,
  "notebook.breadcrumbs.showCodeCells": false,
  "editor.linkedEditing": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "redhat.telemetry.enabled": false,
  "workbench.enableExperiments": false,
  "workbench.settings.enableNaturalLanguageSearch": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "sync.gist": "6f1b1f97ee58176b2acdbf93b9ea4e4b",
  "sync.removeExtensions": true,
  "sync.forceUpload": true,
  "errorLens.enabledDiagnosticLevels": ["error", "warning"],
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "C_Cpp.clang_format_fallbackStyle": "Google",
  "[java]": {
    "editor.defaultFormatter": "redhat.java"
  },
  "workbench.productIconTheme": "material-product-icons",
  "sync.autoUpload": true,
  "material-icon-theme.folders.color": "#42a5f5",
  "workbench.editor.historyBasedLanguageDetection": false,
  "workbench.localHistory.enabled": false,
  "terminal.integrated.shellIntegration.history": 0,
  "workbench.localHistory.maxFileEntries": 0,
  "workbench.sideBar.location": "right",
  "zentabs.applyLimitFor": "editorGroup",
  "zentabs.maximumOpenedTabs": 1,
  "workbench.startupEditor": "none",
  "zenMode.centerLayout": false,
  "zenMode.fullScreen": false,
  "zenMode.hideLineNumbers": false,
  "editor.copyWithSyntaxHighlighting": false,
  "editor.foldingHighlight": false,
  "editor.folding": false,
  "editor.glyphMargin": false,
  "editor.guides.bracketPairs": "active",
  "editor.tabCompletion": "onlySnippets",
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.find.addExtraSpaceOnTop": false,
  "editor.minimap.enabled": false,
  "files.simpleDialog.enable": true,
  "zentabs.switchWithCurrentTab": true,
  "zenMode.hideStatusBar": false,
  "explorer.openEditors.visible": 0,
  "terminal.integrated.confirmOnExit": "hasChildProcesses",
  "vim.statusBarColorControl": false,
  "workbench.colorTheme": "One Dark Pro Darker",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "cSpell.enabled": true,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.perEditorGroup": true,
  "workbench.editor.limit.value": 1
}
